# Resend email configuration
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=info@btxclinicalresearch.com
CONTACT_EMAIL=info@btxclinicalresearch.com

# Cloudflare Turnstile bot protection (optional but recommended)
PUBLIC_TURNSTILE_SITE_KEY=0x00000000000000000000AA
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000000000000

# Optional: Upstash Redis / Vercel KV for rate limiting
# If omitted, rate limiting is disabled.
KV_REST_API_URL=https://your-kv-url.upstash.io
KV_REST_API_TOKEN=your-kv-token
