---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found | BTX Clinical Research" description="The page you are looking for does not exist.">
  <section class="section pt-32 text-center">
    <div class="container max-w-2xl mx-auto">
      <h1 class="text-7xl font-heading font-bold gradient-text mb-6">404</h1>
      <h2 class="text-2xl font-heading font-bold mb-4">Page not found</h2>
      <p class="text-brand-muted text-lg mb-8">
        The page you are looking for does not exist or has been moved.
      </p>
      <a href="/" class="btn-primary">Go home</a>
    </div>
  </section>
</BaseLayout>
