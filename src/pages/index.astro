---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import CTABanner from '@/components/sections/CTABanner.astro';
import ContactForm from '@/components/ui/ContactForm.astro';
import { site, nav } from '@/data/site';
import { seoConfig } from '@/lib/seo/config';

const pageTitle = `${seoConfig.siteName} — Innovation & Care`;
const pageDescription = seoConfig.defaultDescription;
const ogImage = seoConfig.defaultImage;

const values = [
  {
    title: 'Teamwork',
    text: 'We believe in the power of collaboration and teamwork. We encourage open communication, respect, and support to create a positive and inclusive work environment.',
  },
  {
    title: 'Innovation',
    text: 'We are dedicated to exploring new ideas and technologies to advance medical knowledge and enhance patient care. We aim to drive positive change in healthcare and research.',
  },
  {
    title: 'Integrity',
    text: 'We are committed to honesty, transparency, and ethical conduct. We strive to maintain trust through our actions and decisions.',
  },
];

const team = [
  {
    name: 'Andre Rosas, MD',
    role: 'Co-owner / Medical Director',
    image: '/images/team-andre.jpg',
  },
  {
    name: 'Rosa Rosas, MD',
    role: 'CEO / Founder',
    image: '/images/team-icon.svg',
  },
  {
    name: 'Etienne Rosas, PhD',
    role: 'Research & Strategy',
    image: '/images/team-etienne.png',
  },
  {
    name: 'Jared Parkin',
    role: 'Clinical Research',
    image: '/images/team-icon.svg',
  },
  {
    name: 'Alejandro Reyes, MSHS',
    role: 'Care Coordinator',
    image: '/images/team-alejandro.jpg',
  },
];

const capabilities = [
  { title: 'Office', desc: '1,650 square foot office with four examination rooms and secured WiFi.' },
  { title: 'Lounge', desc: 'Spacious lounge area with amenities for patients and visitors.' },
  { title: 'Lab', desc: 'Fully equipped on-site laboratory for sample processing.' },
  { title: 'Storage', desc: 'Pharmacy-grade refrigerator and freezer for medication and samples.' },
  { title: 'Meeting', desc: 'Conference room for team meetings and sponsor visits.' },
  { title: 'Vitals', desc: 'Calibrated vital signs equipment for accurate assessments.' },
  { title: 'Security', desc: 'Secured medication storage area with controlled access.' },
  { title: 'Station', desc: 'Clinical coordinator workstation for study management.' },
  { title: 'ECG', desc: 'AED and 12-lead ECG equipment available on-site.' },
];
---

<BaseLayout title={pageTitle} description={pageDescription} image={ogImage}>
  <Hero
    heading="BTX Clinical Research"
    headingHighlight="Innovation & Care"
    subheading="A clinical research organization and site based in Brownsville, Texas."
    primaryCTA={{ label: 'Contact Us', href: '#contact' }}
    secondaryCTA={{ label: 'Call Us', href: site.phoneHref }}
    backgroundImage="/images/btx-building.jpg"
    showStats={false}
  />

  <section id="mission" class="section bg-brand-secondary/30">
    <div class="container max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <span class="badge mb-4">Mission & Vision</span>
          <h2 class="text-headline font-heading text-brand-text mb-6">
            Reliable, professional, state-of-the-art clinical trial support
          </h2>
          <div class="space-y-4 text-brand-muted text-lg leading-relaxed">
            <p>
              BTX Clinical Research is committed to providing reliable, professional, and state-of-the-art support and management of clinical trials.
            </p>
            <p>
              By leveraging the experience and expertise of its staff and partners in a medically underserved area, BTX strives to facilitate innovative solutions that advance medical treatment everywhere, empower our associates to reliably expand their health-related research, and improve our community's overall quality of life.
            </p>
          </div>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href={site.phoneHref} class="btn-primary">Call Us</a>
            <a href="#contact" class="btn-secondary">Send a Message</a>
          </div>
        </div>
        <div class="order-1 lg:order-2 relative rounded-2xl overflow-hidden shadow-card">
          <img src="/images/btx-building.jpg" alt="BTX Clinical Research building" class="w-full h-auto object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="values" class="section">
    <div class="container max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="badge mb-4">Our Core Values</span>
        <h2 class="text-headline font-heading text-brand-text mb-4">The principles that guide our work</h2>
        <p class="text-brand-muted text-lg">Our values shape how we conduct research, treat patients, and partner with sponsors.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {values.map((value) => (
          <div class="card-hover p-8">
            <h3 class="text-2xl font-heading font-bold text-brand-text mb-4">{value.title}</h3>
            <p class="text-brand-muted leading-relaxed">{value.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="team" class="section bg-brand-secondary/30">
    <div class="container max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="badge mb-4">Our Research Team</span>
        <h2 class="text-headline font-heading text-brand-text mb-4">Meet the team</h2>
        <p class="text-brand-muted text-lg">Experienced medical researchers and coordinators dedicated to advancing clinical research in the Rio Grande Valley.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {team.map((member) => (
          <div class="card text-center p-6">
            <div class="w-32 h-32 mx-auto mb-5 rounded-full overflow-hidden bg-brand-surface border border-brand-border">
              <img src={member.image} alt={member.name} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <h3 class="text-xl font-heading font-bold text-brand-text mb-1">{member.name}</h3>
            <p class="text-brand-azure text-sm font-medium">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="capabilities" class="section">
    <div class="container max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="badge mb-4">Our Site Capabilities</span>
        <h2 class="text-headline font-heading text-brand-text mb-4">A facility built for clinical research</h2>
        <p class="text-brand-muted text-lg">Our Brownsville site is equipped to support a wide range of clinical study needs.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {capabilities.map((cap) => (
          <div class="card-hover p-6">
            <h3 class="text-xl font-heading font-bold text-brand-text mb-2">{cap.title}</h3>
            <p class="text-brand-muted leading-relaxed">{cap.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="contact" class="section bg-brand-secondary/30">
    <div class="container max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <span class="badge mb-4">Get In Touch</span>
          <h2 class="text-headline font-heading text-brand-text mb-6">Contact us today</h2>
          <p class="text-brand-muted text-lg mb-8">
            We look forward to working with you. Fill out the form and we will contact you as soon as possible.
          </p>
          <div class="space-y-4 text-brand-muted">
            <p class="flex items-start gap-3">
              <svg class="w-5 h-5 mt-1 text-brand-azure" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
              <span>{site.address}</span>
            </p>
            <p class="flex items-center gap-3">
              <svg class="w-5 h-5 text-brand-azure" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
              <a href={site.phoneHref} class="hover:text-brand-highlight transition-colors">{site.phone}</a>
            </p>
            <p class="flex items-center gap-3">
              <svg class="w-5 h-5 text-brand-azure" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
              <a href={`mailto:${site.email}`} class="hover:text-brand-highlight transition-colors">{site.email}</a>
            </p>
            <p class="flex items-center gap-3">
              <svg class="w-5 h-5 text-brand-azure" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              <span>{site.hours}</span>
            </p>
          </div>
        </div>
        <div class="card p-6 md:p-8">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
