---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/data/site';

const title = 'BTX Clinical Research — Innovation & Care';
const description = 'BTX Clinical Research is a clinical research organization and site based in Brownsville, Texas. Reliable, professional, state-of-the-art clinical trial support.';

const values = [
  {
    title: 'Teamwork',
    icon: 'fa-network-wired',
    text: 'We believe in the power of collaboration and teamwork. We encourage open communication, respect, and support to create a positive and inclusive work environment.',
  },
  {
    title: 'Innovation',
    icon: 'fa-fast-forward',
    text: 'We are dedicated to exploring new ideas and technologies to advance medical knowledge and enhance patient care. We aim to drive positive change in healthcare and research.',
  },
  {
    title: 'Integrity',
    icon: 'fa-hand-rock',
    text: 'We are committed to honesty, transparency, and ethical conduct. We strive to maintain that trust through our actions and decisions.',
  },
];

const team = [
  { name: 'Andre Rosas, MD', role: 'Co-owner/Medical director', image: '/images/team-andre.jpg' },
  { name: 'Rosa Rosas, MD', role: 'CEO/Founder', image: '/images/team-icon.png' },
  { name: 'Etienne Rosas, PhD', role: '', image: '/images/team-etienne.png' },
  { name: 'Jared Parkin', role: '', image: '/images/team-icon.png' },
  { name: 'Alejandro Reyes, MSHS', role: 'Care Coordinator', image: '/images/team-alejandro.jpg' },
];

const capabilities = [
  { title: 'Office', icon: 'far fa-building', description: '1,650 Square foot office with four examination rooms with secured WiFi' },
  { title: 'Lounge', icon: 'far fa-coffee', description: 'Spacious Lounge Area with amenities' },
  { title: 'Lab', icon: 'far fa-atom', description: 'Fully equipped on-site laboratory' },
  { title: 'Storage', icon: 'far fa-store', description: 'Pharmacy-grade refrigerator and freezer' },
  { title: 'Meeting', icon: 'far fa-comments', description: 'Conference Room' },
  { title: 'Vitals', icon: 'far fa-heartbeat', description: 'Calibrated Vital signs equipment' },
  { title: 'Security', icon: 'far fa-lock', description: 'Secured medication storage area' },
  { title: 'Station', icon: 'far fa-tablet-alt', description: 'Clinical coordinator workstation' },
  { title: 'ECG', icon: 'far fa-heart', description: 'AED/12 lead ECG' },
];
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="relative bg-white overflow-hidden" aria-label="Hero">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center py-16 lg:py-24">
        <div class="order-2 lg:order-1">
          <h1 class="text-display mb-2">BTX Clinical Research</h1>
          <h2 class="text-subhead mb-6">Innovation & Care</h2>
          <p class="text-lg text-brand-primary mb-8 max-w-xl">
            BTX Clinical Research is a clinical research organization and site based in Brownsville, Texas.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href={site.phoneHref} class="btn-primary">Call Us</a>
            <a href="#contact" class="btn-outline">Contact Us</a>
          </div>
        </div>

        <div class="order-1 lg:order-2 grid grid-cols-2 gap-4">
          <img
            src="/images/building.jpg"
            alt="BTX Clinical Research building exterior"
            class="w-full h-64 md:h-80 object-cover rounded-lg shadow-card"
          />
          <img
            src="/images/building-2.jpg"
            alt="BTX Clinical Research facility interior"
            class="w-full h-64 md:h-80 object-cover rounded-lg shadow-card"
          />
        </div>
      </div>
    </div>

    <div class="wave-bottom" aria-hidden="true">
      <svg viewBox="0 0 1000 100" preserveAspectRatio="none">
        <path class="shape-fill" d="M421.9,6.5c22.6-2.5,51.5,0.4,75.5,5.3c23.6,4.9,70.9,23.5,100.5,35.7c75.8,32.2,133.7,44.5,192.6,49.7
        c23.6,2.1,48.7,3.5,103.4-2.5c54.7-6,106.2-25.6,106.2-25.6V0H0v30.3c0,0,72,32.6,158.4,30.5c39.2-0.7,92.8-6.7,134-22.4
        c21.2-8.1,52.2-18.2,79.7-24.2C399.3,7.9,411.6,7.5,421.9,6.5z"></path>
      </svg>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section id="mission" class="section bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center lg:text-left lg:mx-0">
        <h2 class="text-headline mb-6">Mission & Vision</h2>
        <p class="text-lg text-brand-secondary mb-4">
          BTX Clinical Research is committed to providing reliable, professional, and state-of-the-art support and management of clinical trials.
        </p>
        <p class="text-brand-text mb-8">
          By leveraging the experience and expertise of its staff and partners in a medically underserved area, BTX strives to facilitate innovative solutions that advance medical treatment everywhere, empower our associates to reliably expand their health-related research, and improve our community's overall quality of life.
        </p>
        <a href="#contact" class="btn-primary">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section id="values" class="section section-alt">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-headline mb-4">Our Core Values</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {values.map((value) => (
          <div class="text-center">
            <div class="w-14 h-14 mx-auto mb-5 rounded-xl bg-brand-primary flex items-center justify-center text-white text-2xl">
              <i class={`fas ${value.icon}`} aria-hidden="true"></i>
            </div>
            <h3 class="text-xl font-semibold text-brand-heading mb-3">{value.title}</h3>
            <p class="text-brand-text">{value.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Research Team -->
  <section id="team" class="section bg-white">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-headline mb-4">Our Research Team</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {team.map((member) => (
          <div class="text-center">
            <div class="aspect-square overflow-hidden rounded-lg mb-4 bg-brand-bluegray">
              <img
                src={member.image}
                alt={member.name}
                class="w-full h-full object-cover"
              />
            </div>
            <h3 class="text-xl font-semibold text-brand-heading">{member.name}</h3>
            {member.role && <p class="text-brand-secondary font-medium">{member.role}</p>}
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="#team" class="btn-outline">Learn More About Our Team</a>
      </div>
    </div>
  </section>

  <!-- Site Capabilities -->
  <section id="capabilities" class="section section-alt">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-headline mb-4">Our Site Capabilities</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {capabilities.map((cap) => (
          <div class="group [perspective:1000px]">
            <div class="relative h-56 transition-transform duration-500 [transform-style:preserve-3d] group-hover:[transform:rotateY(180deg)]">
              <!-- Front -->
              <div class="absolute inset-0 backface-hidden bg-brand-primary rounded-lg flex flex-col items-center justify-center p-6 text-center">
                <div class="w-14 h-14 mb-4 rounded-full bg-white/10 flex items-center justify-center text-white text-2xl">
                  <i class={cap.icon} aria-hidden="true"></i>
                </div>
                <h3 class="text-xl font-semibold text-white">{cap.title}</h3>
              </div>
              <!-- Back -->
              <div class="absolute inset-0 backface-hidden [transform:rotateY(180deg)] bg-brand-accent rounded-lg flex items-center justify-center p-6 text-center">
                <p class="text-white">{cap.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .backface-hidden {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
</style>
