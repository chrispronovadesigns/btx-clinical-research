---
import ContactForm from '@/components/ui/ContactForm.astro';
import { site, social } from '@/data/site';

const googleReview = social.find((s) => s.label.toLowerCase().includes('google'));
---

<footer class="bg-white text-brand-text">
  <!-- Contact CTA -->
  <section id="contact" class="relative bg-brand-light py-16 overflow-hidden">
    <div
      class="absolute inset-0 bg-contain bg-center bg-no-repeat opacity-10"
      style="background-image: url('/images/btx-logo-square.png');"
      aria-hidden="true"
    ></div>
    <div class="container relative z-10">
      <div class="max-w-3xl mx-auto text-center mb-8">
        <h2 class="text-headline mb-3 text-brand-heading">Get in contact with us today!</h2>
        <p class="text-lg text-brand-secondary">We look forward to working with you.</p>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="bg-white pb-16">
    <div class="container">
      <p class="text-center text-brand-secondary mb-8">
        FIll out the form below and we will cantact you as soon as possible
      </p>
      <div class="max-w-2xl mx-auto">
        <ContactForm />
      </div>
    </div>
  </section>

  <!-- Main Footer -->
  <div class="border-t border-brand-border">
    <div class="container py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <div>
          <p class="text-brand-text leading-relaxed">
            BTX Clinical Research is an independent, privately owned clinical research site in Brownsville, TX.
          </p>
        </div>

        <div class="space-y-4">
          <h3 class="text-lg font-semibold text-brand-heading">Get In Touch</h3>
          <div class="space-y-3 text-sm text-brand-text">
            <p>{site.address}</p>
            <p>
              <span class="font-medium">Email:</span>
              <a href={`mailto:${site.email}`} class="text-brand-secondary hover:text-brand-accent transition-colors">{site.email}</a>
            </p>
            <p>
              <span class="font-medium">Phone:</span>
              <a href={site.phoneHref} class="text-brand-secondary hover:text-brand-accent transition-colors">{site.phone}</a>
            </p>
            <p>
              <span class="font-medium">Hours:</span> {site.hours}
            </p>
            {googleReview && (
              <p class="pt-1">
                <a
                  href={googleReview.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-brand-secondary hover:text-brand-accent transition-colors font-medium"
                >
                  Review Us on Google
                </a>
              </p>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="bg-brand-accent text-white">
    <div class="container py-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm">
      <p>© 2025 All Rights Reserved. BTX Clinical Research</p>
      <p>
        Developed by Pronova Designs
        <a href="https://pronovadesigns.com/brownsville-web-development-company-texas/" target="_blank" rel="noopener noreferrer" class="text-white hover:text-brand-primary transition-colors">Website Dev</a>
        <a href="https://pronovadesigns.com/brownsville-texas-seo-company-digital-marketing/" target="_blank" rel="noopener noreferrer" class="text-white hover:text-brand-primary transition-colors"> | Digital Marketing</a>
      </p>
    </div>
  </div>
</footer>
