---
import { nav } from '@/data/site';

const navLinks = nav.en;
const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 md:top-10 inset-x-0 z-50 bg-brand-secondary border-b border-brand-border/80" id="site-header">
  <nav class="w-full flex items-center justify-between h-20 px-4 md:px-8 lg:px-12">
    <a href="/" class="flex items-center shrink-0" aria-label="BTX Clinical Research Home">
      <img src="/images/btx-logo.png" alt="BTX Clinical Research" class="h-10 w-auto" />
    </a>

    <ul class="hidden lg:flex items-center gap-1" role="list">
      {navLinks.map((link) => (
        <li class="relative">
          <a
            href={link.href}
            class:list={[
              'inline-flex items-center gap-1 px-3 py-1 rounded-lg text-base font-medium leading-none text-brand-text/80 hover:text-brand-highlight transition-colors',
              currentPath === link.href && 'text-brand-highlight',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <a href="#contact" class="btn-primary hidden sm:inline-flex">Contact Us</a>

      <button class="lg:hidden p-2 text-brand-text" aria-label="Open menu" id="menu-toggle">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden lg:hidden bg-brand-secondary border-t border-brand-border px-4 py-4">
    <ul class="space-y-2" role="list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="block px-3 py-2 text-brand-text hover:text-brand-highlight">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script is:inline>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
