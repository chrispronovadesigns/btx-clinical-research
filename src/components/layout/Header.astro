---
import { nav } from '@/data/site';

const navLinks = nav.en;
---

<header class="sticky top-0 z-50 bg-white border-b border-brand-border shadow-sm">
  <div class="container">
    <div class="flex items-center justify-between h-20">
      <a href="/" class="flex items-center shrink-0" aria-label="BTX Clinical Research Home">
        <img src="/images/btx-logo.png" alt="BTX Clinical Research" class="h-12 w-auto" />
      </a>

      <nav class="hidden lg:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-brand-primary font-medium hover:text-brand-accent transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <button class="lg:hidden p-2 text-brand-primary" aria-label="Open menu" id="menu-toggle">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-brand-border">
    <div class="container py-4">
      <ul class="space-y-3" role="list">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="block text-brand-primary font-medium hover:text-brand-accent transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</header>

<script is:inline>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
