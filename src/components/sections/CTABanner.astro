---
import { site } from '@/data/site';

interface Props {
  heading?: string;
  subheading?: string;
  callLabel?: string;
  chatLabel?: string;
  href?: string;
}

const {
  heading = 'Start a conversation with our team',
  subheading = 'Reach out to learn how BTX Clinical Research can support your next clinical trial in the Rio Grande Valley.',
  callLabel = 'Call now',
  chatLabel = 'Contact us',
  href = '#contact',
} = Astro.props;
---

<section class="section-lg">
  <div class="container">
    <div class="relative rounded-3xl overflow-hidden bg-gradient-brand p-12 md:p-20 lg:p-24 text-center shadow-glow-blue">
      <div class="absolute inset-0 opacity-10" aria-hidden="true"
           style="background-image: radial-gradient(circle at 20% 50%, white 1px, transparent 1px), radial-gradient(circle at 80% 50%, white 1px, transparent 1px); background-size: 40px 40px;" />

      <div class="relative z-10">
        <h2 class="text-headline font-heading text-white mb-6">{heading}</h2>
        <p class="text-white/80 text-lg md:text-xl mb-10 max-w-2xl mx-auto">{subheading}</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href={href}
             class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-brand-azure font-semibold rounded-lg hover:bg-white/90 transition-colors shadow-card">
            {chatLabel}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href={site.phoneHref}
             class="inline-flex items-center gap-2 px-8 py-3.5 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors">
            {callLabel}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
