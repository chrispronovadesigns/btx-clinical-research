---
import { site } from '@/data/site';

interface Props {
  heading: string;
  headingHighlight?: string;
  subheading: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
  showStats?: boolean;
  descriptor?: string;
  isHome?: boolean;
  backgroundImage?: string;
  title?: string;
  callLabel?: string;
}

const {
  heading,
  headingHighlight,
  subheading,
  primaryCTA = { label: 'Contact Us', href: '#contact' },
  secondaryCTA = { label: 'Learn More', href: '#mission' },
  showStats = true,
  descriptor,
  isHome = false,
  backgroundImage,
  title,
  callLabel = 'Call now',
} = Astro.props;

const before = headingHighlight ? heading.split(headingHighlight)[0] : heading;
const after  = headingHighlight ? heading.split(headingHighlight)[1] ?? '' : '';

const HeadingTag = title ? 'h2' : 'h1';

const stats = [
  { value: '5+', label: 'Years of research' },
  { value: '1,650', label: 'Sq ft facility' },
  { value: 'Brownsville', label: 'Texas based' },
];
---

<section class:list={[
  'relative w-full flex items-center justify-center overflow-hidden -mt-16 md:-mt-[104px]',
  isHome ? 'min-h-[100svh]' : 'min-h-[70vh] pt-16 md:pt-[104px]',
]}>
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    {backgroundImage ? (
      <>
        <img
          src={backgroundImage}
          alt=""
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-brand-primary/80 via-brand-primary/70 to-brand-primary" />
      </>
    ) : (
      <>
        <div class="absolute inset-0 bg-gradient-to-b from-brand-primary via-brand-secondary to-brand-primary" />
        <div class="absolute top-1/4 -left-1/4 w-[800px] h-[800px] bg-brand-abyss/20 rounded-full blur-[120px]" />
        <div class="absolute bottom-1/4 -right-1/4 w-[600px] h-[600px] bg-brand-highlight/6 rounded-full blur-[120px]" />
      </>
    )}
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(22,82,176,0.4) 1px, transparent 1px), linear-gradient(90deg, rgba(22,82,176,0.4) 1px, transparent 1px); background-size: 80px 80px;" />
  </div>

  <div class="w-full px-4 md:px-8 lg:px-12 py-28 md:py-36 text-center relative z-10">
    {title && (
      <h1 class="font-bold font-heading leading-[1.05] pt-4 mb-4 animate-slide-up text-7xl md:text-9xl lg:text-[9rem] xl:text-[11rem] hero-title-gradient">
        {title}
      </h1>
    )}

    <HeadingTag class:list={[
      'font-bold font-heading leading-[1.05] mb-6 animate-slide-up',
      title ? 'text-4xl md:text-5xl lg:text-6xl xl:text-7xl' : 'text-5xl md:text-7xl lg:text-[5.5rem] xl:text-[6.5rem]',
    ]}>
      {before}
      {headingHighlight && <span class={title ? '' : 'gradient-text'}>{headingHighlight}</span>}
      {after}
    </HeadingTag>

    {descriptor && (
      <h3 class="text-brand-highlight font-heading font-semibold text-lg md:text-2xl lg:text-3xl tracking-[0.15em] uppercase mb-8 animate-fade-in">
        {descriptor}
      </h3>
    )}

    <p class:list={[
      'text-brand-muted leading-relaxed mx-auto mb-12 animate-fade-in',
      'text-xl md:text-2xl lg:text-3xl max-w-4xl',
    ]}>
      {subheading}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in">
      <a href={primaryCTA.href} class="btn-big">
        {primaryCTA.label}
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
      <a href={secondaryCTA.href} class="btn-big-outline">
        {secondaryCTA.label}
      </a>
      <a href={site.phoneHref} class="btn-big-outline sm:hidden">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
        </svg>
        {callLabel}
      </a>
    </div>

    {showStats && (
      <div class="mt-24 grid grid-cols-3 gap-8 md:gap-12 max-w-2xl mx-auto">
        {stats.map((stat) => (
          <div class="text-center">
            <p class="text-4xl md:text-6xl font-bold gradient-text font-heading">{stat.value}</p>
            <p class="text-brand-muted text-xs md:text-sm mt-2">{stat.label}</p>
          </div>
        ))}
      </div>
    )}
  </div>

  {isHome && (
    <a href="#services" class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 animate-bounce text-brand-muted hover:text-brand-azure transition-colors cursor-pointer p-2" aria-label="Scroll to services">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7" />
      </svg>
    </a>
  )}
</section>
